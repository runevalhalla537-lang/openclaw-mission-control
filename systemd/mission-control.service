[Unit]
Description=OpenClaw Mission Control
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=openclaw
WorkingDirectory=/home/openclaw/.openclaw/workspace/mission-control/backend
Environment=MC_HOST=0.0.0.0
Environment=MC_PORT=8787
Environment=OPENCLAW_BIN=/home/<user>/.npm-global/bin/openclaw
Environment=PATH=/home/openclaw/.npm-global/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
Environment=SPARK_OLLAMA=http://<spark-host>:11434
Environment=SPARK_METRICS_URL=http://<spark-host>:8766/metrics
ExecStart=/home/openclaw/.openclaw/workspace/mission-control/.venv/bin/python /home/openclaw/.openclaw/workspace/mission-control/backend/app.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
